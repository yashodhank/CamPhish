%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#3b82f6','primaryTextColor': '#ffffff','primaryBorderColor': '#2563eb','lineColor': '#6b7280','secondaryColor': '#f59e0b','tertiaryColor': '#10b981','noteBkgColor': '#f3f4f6','noteTextColor': '#1f2937','fontSize': '14px'}}}%%
flowchart TD
  subgraph DEPLOY["Deployment Modes"]
    direction LR
    LOCAL["🖥 Local Mode\nDocker + Tunnel"]
    SELF["☁ Self-Hosted\nVPS + Domain + Proxy"]
    COOLIFY["📦 Coolify Mode\nPanel-Managed"]
  end

  subgraph TUNNEL["Tunnel Layer — Local Mode"]
    direction LR
    NGROK["Ngrok Container\nngrok/ngrok:latest"]
    CFLARED["Cloudflared Container\ncloudflare/cloudflared:latest"]
  end

  subgraph PROXY["Proxy Layer — Self-Hosted Mode"]
    direction LR
    CADDY["Caddy\nAuto-TLS"]
    TRAEFIK["Traefik\nDocker Discovery"]
    NGINX["Nginx\nCertbot Companion"]
  end

  subgraph APP_LAYER["Application Layer"]
    direction LR
    APP["CamPhish App\nPHP 8.2 + Apache :80"]
    DASH["Dashboard\nPHP 8.2 + Apache :80"]
  end

  subgraph STORAGE["Storage Layer — Persistent Volumes"]
    direction LR
    CAPTURES[("📷 Captures\n/data/captures")]
    LOCATIONS[("📍 Locations\n/data/locations")]
    LOGS[("📋 Logs\n/data/logs")]
    CONFIG[("⚙ Config\n/data/config")]
  end

  subgraph EXTERNAL["External Systems"]
    direction LR
    TARGET["🎯 Target Device\nBrowser"]
    OPERATOR["👤 Operator\nCLI + Dashboard"]
    CF_DNS["🌐 Cloudflare DNS\nAPI"]
    REGISTRY["📦 Container Registry\nghcr.io / Docker Hub"]
  end

  subgraph BUILD["Build System"]
    direction LR
    PACK["pack CLI\nCloud Native Buildpacks"]
    BUILDER["Heroku Builder\nheroku/builder:24"]
    DOCKERFILE["Dockerfile\nFallback Build"]
  end

  LOCAL --> NGROK
  LOCAL --> CFLARED
  SELF --> CADDY
  SELF --> TRAEFIK
  SELF --> NGINX
  NGROK & CFLARED --> APP
  CADDY & TRAEFIK & NGINX --> APP
  CADDY & TRAEFIK & NGINX --> DASH
  APP --> CAPTURES
  APP --> LOCATIONS
  APP --> LOGS
  APP --> CONFIG
  DASH --> CAPTURES
  DASH --> LOCATIONS
  DASH --> LOGS
  DASH --> CONFIG
  TARGET -->|"HTTPS Link"| NGROK
  TARGET -->|"HTTPS Link"| CFLARED
  TARGET -->|"HTTPS"| CADDY
  TARGET -->|"HTTPS"| TRAEFIK
  TARGET -->|"HTTPS"| NGINX
  OPERATOR -->|"CLI"| APP
  OPERATOR -->|"Browser"| DASH
  SELF -->|"DNS Records"| CF_DNS
  PACK --> BUILDER
  BUILDER -->|"OCI Image"| REGISTRY
  DOCKERFILE -->|"Docker Image"| REGISTRY
  REGISTRY --> APP
  REGISTRY --> DASH

  style DEPLOY fill:#eff6ff,stroke:#3b82f6,color:#1e3a5f
  style TUNNEL fill:#fef3c7,stroke:#f59e0b,color:#78350f
  style PROXY fill:#ecfdf5,stroke:#10b981,color:#064e3b
  style APP_LAYER fill:#faf5ff,stroke:#8b5cf6,color:#3b0764
  style STORAGE fill:#fef2f2,stroke:#ef4444,color:#7f1d1d
  style EXTERNAL fill:#f0fdf4,stroke:#22c55e,color:#14532d
  style BUILD fill:#fff7ed,stroke:#f97316,color:#7c2d12
