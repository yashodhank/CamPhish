stateDiagram-v2
  [*] --> LinkGenerated: 🚀 Operator starts CamPhish

  state LinkGenerated {
    [*] --> WaitingForTarget
    WaitingForTarget --> LinkOpened: 🎯 Target clicks link
  }

  state LinkOpened {
    [*] --> IPCaptured: 📋 IP + UA logged
    IPCaptured --> LocationRequested: 📍 JS geolocation call
    state LocationRequested {
      [*] --> PermissionPrompt: 🔔 Browser shows location dialog
      PermissionPrompt --> LocationGranted: ✅ User clicks Allow
      PermissionPrompt --> LocationDenied: ❌ User clicks Block
      PermissionPrompt --> LocationTimeout: ⏰ User ignores dialog
    }
    LocationGranted --> LocationSaved: 💾 POST to location.php
    LocationDenied --> RedirectToTemplate: handleError()
    LocationTimeout --> RedirectToTemplate: handleError()
    LocationSaved --> RedirectToTemplate: redirectToMainPage()
  }

  state RedirectToTemplate {
    [*] --> TemplateLoaded: 📄 Template page renders
    TemplateLoaded --> CameraRequested: 📷 JS getUserMedia call
    state CameraRequested {
      [*] --> CameraPrompt: 🔔 Browser shows camera dialog
      CameraPrompt --> CameraGranted: ✅ User clicks Allow
      CameraPrompt --> CameraDenied: ❌ User clicks Block
    }
    CameraGranted --> CaptureTaken: 🖼 canvas.toDataURL + POST
    CameraDenied --> TemplateDisplayed: Silent fail
    CaptureTaken --> TemplateDisplayed: 💿 Image saved to /data/captures/
  }

  state TemplateDisplayed {
    [*] --> ContinuousCapture: ⏱ Template JS interval timer
    ContinuousCapture --> ContinuousCapture: 📷 Periodic camera shots
    ContinuousCapture --> TargetLeaves: 🚪 Target closes tab
  }

  TargetLeaves --> [*]

  style LinkGenerated fill:#eff6ff,stroke:#3b82f6,color:#1e3a5f
  style LinkOpened fill:#fef3c7,stroke:#f59e0b,color:#78350f
  style RedirectToTemplate fill:#ecfdf5,stroke:#10b981,color:#064e3b
  style TemplateDisplayed fill:#faf5ff,stroke:#8b5cf6,color:#3b0764
