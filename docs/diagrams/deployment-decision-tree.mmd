flowchart TD
  START((Start)) --> Q1{"Where are you deploying?"}

  Q1 -->|"Local Machine"| Q2{"Need public URL?"}
  Q1 -->|"VPS / Cloud VM"| Q3{"Have a domain name?"}
  Q1 -->|"Coolify Panel"| COOLIFY["Use Coolify Profile\nDEPLOY_MODE=coolify"]

  Q2 -->|"Yes, via ngrok"| NGROK_SETUP["Set NGROK_AUTHTOKEN\nTUNNEL=ngrok"]
  Q2 -->|"Yes, via Cloudflare"| CF_SETUP["TUNNEL=cloudflared\n(no auth needed)"]
  Q2 -->|"No, LAN only"| LAN["TUNNEL=none\nAccess via localhost:3333"]

  Q3 -->|"Yes"| Q4{"Using Cloudflare DNS?"}
  Q3 -->|"No, IP only"| IP_ONLY["Set DOMAIN=<ip>\nUse self-hosted profile"]

  Q4 -->|"Yes"| Q5{"Orange Cloud (proxy)?"}
  Q4 -->|"No, other DNS"| MANUAL_DNS["Set DOMAIN=<domain>\nManually create A records"]

  Q5 -->|"Yes (hide origin)"| CF_PROXY["CF_ORANGE_CLOUD=true\nCloudflare hides VPS IP"]
  Q5 -->|"No (DNS only)"| CF_DNS_ONLY["CF_ORANGE_CLOUD=false\nDirect to origin"]

  NGROK_SETUP --> Q6{"Choose reverse proxy?"}
  CF_SETUP --> Q6
  LAN --> DONE

  CF_PROXY --> Q6
  CF_DNS_ONLY --> Q6
  MANUAL_DNS --> Q6
  IP_ONLY --> Q6

  Q6 -->|"Caddy (simplest)"| CADDY["PROXY=caddy\nAuto-TLS, single config file"]
  Q6 -->|"Traefik (Docker-native)"| TRAEFIK["PROXY=traefik\nDocker labels, dashboard"]
  Q6 -->|"Nginx (most control)"| NGINX["PROXY=nginx\nCertbot companion"]

  CADDY --> Q7{"Push to registry?"}
  TRAEFIK --> Q7
  NGINX --> Q7
  COOLIFY --> Q7

  Q7 -->|"Yes"| REGISTRY["Set IMAGE_REGISTRY\npack build --publish"]
  Q7 -->|"No, local build"| LOCAL_BUILD["docker compose build\nor pack build"]

  REGISTRY --> DEPLOY["Run: ./camphish up"]
  LOCAL_BUILD --> DEPLOY

  DEPLOY --> DONE((Deployed))
