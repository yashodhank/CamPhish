# =============================================================================
# CamPhish v4.0 — Enhanced Configuration
# =============================================================================

# --- Deployment Mode ---
DEPLOY_MODE=local

# --- Tunnel ---
TUNNEL=cloudflared
NGROK_AUTHTOKEN=

# --- Build Configuration ---
BUILDER=heroku/builder:24
IMAGE_NAME=camphish-app
IMAGE_REGISTRY=

# --- Dashboard ---
DASHBOARD_PORT=8080

# --- Dashboard Authentication ---
# Set both to enable HTTP Basic Auth on dashboard
DASHBOARD_USER=
DASHBOARD_PASS=

# --- Session ---
SESSION_NAME=default
AUTO_CLEANUP=false

# --- Template ---
DEFAULT_TEMPLATE=1
FESTIVAL_NAME=NewYear
YOUTUBE_VIDEO_ID=dQw4w9WgXcQ

# --- Data Directory ---
DATA_DIR=./data

# --- Logs ---
LOG_TAIL=100

# --- Capture Watermarking ---
# true = overlay session ID + timestamp on captured images
WATERMARK_ENABLED=true
WATERMARK_OPACITY=0.4
WATERMARK_POSITION=bottom-right

# --- WebRTC Streaming ---
# true = use MediaRecorder for video streaming (falls back to canvas snapshots)
WEBRTC_ENABLED=true
WEBRTC_CHUNK_INTERVAL=5000
WEBRTC_VIDEO_BITRATE=500000

# --- AI Template Generation ---
# OpenAI-compatible API for context-aware phishing page generation
AI_ENABLED=false
AI_API_ENDPOINT=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096

# =============================================================================
# Self-Hosted / VPS Mode
# =============================================================================
DOMAIN=
SUBDOMAIN=camphish
PROXY=caddy
LETSENCRYPT_EMAIL=

# =============================================================================
# Cloudflare DNS Integration
# =============================================================================
CF_API_TOKEN=
CF_ZONE_ID=
CF_ORANGE_CLOUD=false

# =============================================================================
# Proxy-specific settings
# =============================================================================
CADDY_IMAGE=caddy:2-alpine
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

TRAEFIK_IMAGE=traefik:v3.3
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8081

NGINX_IMAGE=nginx:alpine
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
