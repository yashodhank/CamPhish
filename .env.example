# CamPhish v2.0.0 — Configuration Reference
# Copy to .env and adjust as needed

# --- Application ---
LISTEN_ADDR=0.0.0.0:8080

# --- Security ---
# DASHBOARD_TOKEN=changeme  # Uncomment to protect dashboard endpoints (Authorization: Bearer <token>)

# --- Data Storage ---
DATA_DIR=/app/data
DATABASE_URL=sqlite:///app/data/camphish.db?mode=rwc

# --- Templates ---
TEMPLATES_DIR=/app/templates
FRONTEND_DIR=/app/frontend/dist

# --- Tunnel ---
TUNNEL_LINK=
TUNNEL=cloudflared
NGROK_AUTHTOKEN=

# --- Self-Healing ---
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=10
GRACEFUL_SHUTDOWN=true
SHUTDOWN_TIMEOUT=30

# --- Self-Optimizing ---
DB_POOL_SIZE=5
DB_WAL=true
ENABLE_COMPRESSION=true
STATIC_CACHE_MAX_AGE=86400
ENABLE_TEMPLATE_CACHE=true

# --- Logging ---
LOG_LEVEL=info
REQUEST_TRACING=true

# --- Build ---
BUILDER=heroku/builder:24
IMAGE_NAME=camphish
IMAGE_REGISTRY=

# --- Version ---
VERSION=2.1.0

# --- TrailBase (DEPRECATED — schema only. Data goes through SQLite.) ---
# TRAILBASE_URL=http://trailbase:4000
# TRAILBASE_API_KEY=
# TRAILBASE_ADMIN_EMAIL=admin@camphish.local
# TRAILBASE_ADMIN_PASSWORD=changeme
