# CamPhish v2.1.0 — Configuration Reference
# Copy to .env and adjust as needed

# =============================================================================
# APPLICATION
# =============================================================================
LISTEN_ADDR=0.0.0.0:8080

# =============================================================================
# SECURITY
# =============================================================================
# DASHBOARD_TOKEN=changeme  # Uncomment to protect dashboard endpoints (Authorization: Bearer <token>)
# CAMPHISH_ACCESS_SEED=my-secret  # Set for a deterministic dashboard access code (persists across restarts)

# =============================================================================
# DATA STORAGE
# =============================================================================
DATA_DIR=/app/data
DATABASE_URL=sqlite:///app/data/camphish.db?mode=rwc

# =============================================================================
# TEMPLATES
# =============================================================================
TEMPLATES_DIR=/app/templates
FRONTEND_DIR=/app/frontend/dist

# =============================================================================
# TUNNEL / PUBLIC URL
# =============================================================================
# Required for templates to generate correct redirect links.
# Set to the public URL where the instance is accessible.
# Examples:
#   TUNNEL_URL=https://camphish.example.com
#   TUNNEL_URL=https://my-tunnel.try.cloudflare.com
TUNNEL_LINK=
TUNNEL_URL=
TUNNEL=cloudflared
NGROK_AUTHTOKEN=

# =============================================================================
# COOLIFY DEPLOYMENT (docker-compose.coolify.yml)
# =============================================================================
# These are auto-injected by Coolify via magic environment variables.
# Do NOT set them manually — Coolify handles them.
# SERVICE_FQDN_CAMPHISH_8080  # Auto-generates FQDN, routes to port 8080
# SERVICE_PASSWORD_CAMPHISH_ACCESS  # Auto-generated dashboard access code

# =============================================================================
# SELF-HEALING
# =============================================================================
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=10
GRACEFUL_SHUTDOWN=true

# =============================================================================
# SELF-OPTIMIZING
# =============================================================================
ENABLE_COMPRESSION=true
ENABLE_TEMPLATE_CACHE=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
REQUEST_TRACING=true

# =============================================================================
# VERSION
# =============================================================================
# Also used as Docker image tag
VERSION=2.1.0

# =============================================================================
# TRAILBASE (DEPRECATED — schema only. Data goes through SQLite.)
# =============================================================================
# TRAILBASE_URL=http://trailbase:4000
# TRAILBASE_API_KEY=
# TRAILBASE_ADMIN_EMAIL=admin@camphish.local
# TRAILBASE_ADMIN_PASSWORD=changeme
# VITE_TRAILBASE_URL=http://localhost:4000  # Uncomment to show TrailBase link in dashboard sidebar
