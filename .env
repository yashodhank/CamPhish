# =============================================================================
# CamPhish v2.0.0 — Rust + React Configuration
# =============================================================================

# --- Application ---
# Listening address for the Rust backend (serves API + dashboard + templates)
LISTEN_ADDR=0.0.0.0:8080

# --- Data Storage ---
DATA_DIR=/app/data
DATABASE_URL=sqlite:///app/data/camphish.db?mode=rwc

# --- Templates ---
TEMPLATES_DIR=/app/templates
FRONTEND_DIR=/app/frontend/dist

# --- Tunnel ---
# TUNNEL is set by the tunnel URL automatically; leave empty for local
TUNNEL_LINK=

# --- Tunnel Selection (docker-compose profiles) ---
# cloudflared = Cloudflare Tunnel (no auth needed)
# ngrok       = Ngrok Tunnel (requires NGROK_AUTHTOKEN)
TUNNEL=cloudflared
NGROK_AUTHTOKEN=

# --- Self-Healing ---
# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30
# Max consecutive failures before container restart
HEALTH_CHECK_RETRIES=3
# Grace period on startup before health checks (seconds)
HEALTH_CHECK_START_PERIOD=10
# Enable graceful shutdown (drain connections)
GRACEFUL_SHUTDOWN=true
# Shutdown timeout (seconds)
SHUTDOWN_TIMEOUT=30

# --- Self-Optimizing ---
# SQLite connection pool size
DB_POOL_SIZE=5
# Enable WAL mode (recommended for concurrent reads)
DB_WAL=true
# Enable response compression (gzip)
ENABLE_COMPRESSION=true
# Static file cache duration (seconds)
STATIC_CACHE_MAX_AGE=86400
# Template cache (in-memory)
ENABLE_TEMPLATE_CACHE=true

# --- Logging ---
# trace, debug, info, warn, error
LOG_LEVEL=info
# Enable request tracing
REQUEST_TRACING=true

# --- Build ---
# Builder image for pack CLI
BUILDER=heroku/builder:24
# OCI image name
IMAGE_NAME=camphish
# Registry for publishing (e.g. ghcr.io/yashodhank)
IMAGE_REGISTRY=

# --- Version ---
VERSION=2.0.0
